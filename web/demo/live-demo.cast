[167.589548, "o", "\r\n\u001b[36;1m$\u001b[0m \u001b[1mpdk ai-setup\u001b[0m\r\n"]
[169.460755, "o", "\u001b[36m╭─\u001b[0m\u001b[36m─────────────────────────────────\u001b[0m\u001b[36m pdk ai-setup - current state \u001b[0m\u001b[36m─────────────────────────────────\u001b[0m\u001b[36m─╮\u001b[0m\r\n\u001b[36m│\u001b[0m \u001b[33mnot configured\u001b[0m                                                                                   \u001b[36m│\u001b[0m\r\n\u001b[36m│\u001b[0m pdk works without AI - this layer only adds an \u001b[1mAI-suggested\u001b[0m second opinion next to the verified  \u001b[36m│\u001b[0m\r\n\u001b[36m│\u001b[0m knowledge-base entry.                                                                            \u001b[36m│\u001b[0m\r\n\u001b[36m╰──────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[169.46263, "o", "\u001b[1mTwo steps to enable AI:\u001b[0m\r\n"]
[169.462991, "o", "  \u001b[1;36m1\u001b[0m. Open \u001b[4;36mhttps://openrouter.ai/keys\u001b[0m and create a free API key.\r\n"]
[169.463367, "o", "     OpenRouter's free tier covers our default model \u001b[1m(\u001b[0m\u001b[1mopenai/gpt-oss-\u001b[0m\u001b[1;92m120b:f\u001b[0m\u001b[1mree\u001b[0m\u001b[1m)\u001b[0m - no credit card.\r\n"]
[169.46371, "o", "  \u001b[1;36m2\u001b[0m. Set the key in your shell. Pick the one that matches your OS:\r\n"]
[169.463819, "o", "\r\n"]
[169.464119, "o", "\u001b[1;36m    # Linux \u001b[0m\u001b[1;36m/\u001b[0m\u001b[1;36m macOS \u001b[0m\u001b[1;36m/\u001b[0m\u001b[1;36m WSL \u001b[0m\u001b[1;36m(\u001b[0m\u001b[1;36mbash, zsh\u001b[0m\u001b[1;36m)\u001b[0m\r\n"]
[169.464364, "o", "    export \u001b[33mPDK_AI_KEY\u001b[0m=\u001b[32m\"sk\u001b[0m\u001b[32m-or-v1-...\"\u001b[0m\r\n"]
[169.464706, "o", "    # Make it persistent by adding the line to ~\u001b[35m/\u001b[0m\u001b[95m.bashrc\u001b[0m or ~\u001b[35m/\u001b[0m\u001b[95m.zshrc\u001b[0m\r\n"]
[169.464841, "o", "\r\n"]
[169.465118, "o", "Optional overrides \u001b[1m(\u001b[0monly if you don't want the OpenRouter default\u001b[1m)\u001b[0m:\r\n"]
[169.46547, "o", "  \u001b[2mPDK_AI_MODEL\u001b[0m    swap the model \u001b[1m(\u001b[0me.g. z-ai/glm-\u001b[1;36m4.5\u001b[0m-air:free\u001b[1m)\u001b[0m\r\n"]
[169.465885, "o", "  \u001b[2mPDK_AI_BASE_URL\u001b[0m swap the endpoint \u001b[1m(\u001b[0many OpenAI-compatible URL\u001b[1m)\u001b[0m\r\n"]
[169.465994, "o", "\r\n"]
[169.466196, "o", "Verify with: \u001b[1mpdk ai-setup --test\u001b[0m\r\n"]
[173.537968, "o", "\r\n\u001b[2m# 14 commands. Real POT gas. No mocks. Portaldot Online Mini Hackathon S1 — 1st place.\u001b[0m\r\n"]
