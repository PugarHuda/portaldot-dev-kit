[152.947957, "o", "\u001b[3m                            pdk report — failures in the last 200 blocks                            \u001b[0m\r\n┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1merror                       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mcount\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mwhat it means                                            \u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┩\r\n│\u001b[31m \u001b[0m\u001b[31mBalances.InsufficientBalance\u001b[0m\u001b[31m \u001b[0m│\u001b[1m \u001b[0m\u001b[1m    4\u001b[0m\u001b[1m \u001b[0m│ You tried to transfer more POT than the sending account   │\r\n│\u001b[31m                              \u001b[0m│\u001b[1m       \u001b[0m│ holds.                                                    │\r\n└──────────────────────────────┴───────┴───────────────────────────────────────────────────────────┘\r\n"]
[152.950999, "o", "\u001b[1;36m4\u001b[0m failed \u001b[1;35mextrinsic\u001b[0m\u001b[1m(\u001b[0ms\u001b[1m)\u001b[0m across \u001b[1;36m1\u001b[0m error \u001b[1;35mtype\u001b[0m\u001b[1m(\u001b[0ms\u001b[1m)\u001b[0m. Use \u001b[1mpdk debug \u001b[0m\u001b[1m<\u001b[0m\u001b[1;95mhash\u001b[0m\u001b[1m>\u001b[0m to dig into one.\r\n"]
