[30.53584, "o", "\r\n\u001b[36;1m$\u001b[0m \u001b[1mpdk doctor --no-liveness\u001b[0m\r\n"]
[32.727946, "o", "\u001b[3m                                 pdk doctor — Portaldot node health                                 \u001b[0m\r\n┌──────────────────┬───────────────────────────────────────────────────────────────────────────────┐\r\n│ Endpoint         │ ws://127.0.0.1:9944                                                           │\r\n│ Chain            │ Development                                                                   │\r\n│ Runtime version  │ 1002                                                                          │\r\n│ Pallets          │ 31                                                                            │\r\n│ Contracts pallet │ present — node v2.0.0 ships contracts API v5, which supports \u001b[1mink! 3.x only\u001b[0m    │\r\n│                  │ (ink! 4.x+ will not deploy)                                                   │\r\n│ Explorer         │ https://portalscan.portaldot.io                                               │\r\n│ AI (optional)    │ not configured - run \u001b[1mpdk ai-setup\u001b[0m to enable                                   │\r\n└──────────────────┴───────────────────────────────────────────────────────────────────────────────┘\r\n"]
[37.822043, "o", "\r\n\u001b[36;1m$\u001b[0m \u001b[1mpdk accounts\u001b[0m\r\n"]
[40.055595, "o", "\u001b[3m          Pre-funded dev accounts — POT ready (no faucet needed)          \u001b[0m\r\n┏━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1maccount\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1maddress                                         \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m      POT\u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━┩\r\n│\u001b[36m \u001b[0m\u001b[36mAlice  \u001b[0m\u001b[36m \u001b[0m│ 5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY │\u001b[32m \u001b[0m\u001b[32m49,999.98\u001b[0m\u001b[32m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mBob    \u001b[0m\u001b[36m \u001b[0m│ 5FHneW46xGXgs5mUiveU4sbTyGBzmstUspZC92UhjJM694ty │\u001b[32m \u001b[0m\u001b[32m50,000.00\u001b[0m\u001b[32m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mCharlie\u001b[0m\u001b[36m \u001b[0m│ 5FLSigC9HGRKVhB9FiEo4Y3koPsNmBmLJbpXg2mp1hXcS59Y │\u001b[32m \u001b[0m\u001b[32m50,000.00\u001b[0m\u001b[32m \u001b[0m│\r\n└─────────┴──────────────────────────────────────────────────┴───────────┘\r\n"]
