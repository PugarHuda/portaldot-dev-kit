{
  "name": "portaldot-pdk-ts",
  "version": "0.2.0-alpha.7",
  "description": "TypeScript companion SDK for pdk (Portaldot Dev Kit) — covers what Python substrate-interface cannot sign on Portaldot's V13 metadata.",
  "type": "module",
  "bin": {
    "pdk-ts": "./dist/index.js"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "tag": "alpha",
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/pdk-data/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests",
    "clean": "rimraf dist",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "portaldot",
    "substrate",
    "cli",
    "typescript",
    "polkadot",
    "blockchain",
    "developer-tools"
  ],
  "author": "Pugar Huda Mantoro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PugarHuda/portaldot-dev-kit.git",
    "directory": "pdk-ts"
  },
  "homepage": "https://portaldot-pdk.vercel.app",
  "bugs": {
    "url": "https://github.com/PugarHuda/portaldot-dev-kit/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/PugarHuda"
  },
  "dependencies": {
    "@polkadot/api": "^16.5.6",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
